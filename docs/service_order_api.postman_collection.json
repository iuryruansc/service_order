{
  "info": {
    "_postman_id": "service-order-api-collection",
    "name": "Service Order API",
    "description": "Colecao para testar a API localmente ou em producao (Railway).\n\n1. Ajuste a variavel `baseUrl` se necessario.\n2. Execute **Auth > Login** (salva o token automaticamente).\n3. Use as demais pastas (rotas protegidas usam Bearer token).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://serviceorder-production.up.railway.app"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "serviceOrderId",
      "value": "1"
    },
    {
      "key": "clientId",
      "value": "1"
    },
    {
      "key": "userId",
      "value": "1"
    },
    {
      "key": "attachmentId",
      "value": "1"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', json.access_token);",
                  "    console.log('Token salvo em accessToken');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "admin@example.com", "description": "E-mail do usuario" },
                { "key": "password", "value": "123456", "type": "text" }
              ]
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Me (usuario autenticado)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Criar usuario",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Novo Usuario\",\n  \"email\": \"novo@example.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/users/"
          }
        },
        {
          "name": "Listar usuarios",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/"
          }
        },
        {
          "name": "Ativar usuario",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/users/{{userId}}/activate"
          }
        },
        {
          "name": "Desativar usuario",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/users/{{userId}}/deactivate"
          }
        }
      ]
    },
    {
      "name": "Clients",
      "item": [
        {
          "name": "Criar cliente",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Cliente Teste\",\n  \"email\": \"cliente@example.com\",\n  \"phone\": \"+5511999999999\"\n}"
            },
            "url": "{{baseUrl}}/clients/"
          }
        },
        {
          "name": "Listar clientes",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/clients/"
          }
        }
      ]
    },
    {
      "name": "Service Orders",
      "item": [
        {
          "name": "Criar ordem",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Troca de tela\",\n  \"description\": \"Notebook com tela quebrada\",\n  \"priority\": \"high\",\n  \"client_id\": {{clientId}},\n  \"responsible_user_id\": {{userId}}\n}"
            },
            "url": "{{baseUrl}}/service-orders/"
          }
        },
        {
          "name": "Listar ordens (com filtros)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/service-orders/?status=open&priority=high&skip=0&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["service-orders", ""],
              "query": [
                { "key": "status", "value": "open", "disabled": true },
                { "key": "priority", "value": "high", "disabled": true },
                { "key": "client_id", "value": "{{clientId}}", "disabled": true },
                { "key": "responsible_user_id", "value": "{{userId}}", "disabled": true },
                { "key": "skip", "value": "0" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Buscar ordem por ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/service-orders/{{serviceOrderId}}"
          }
        },
        {
          "name": "Atualizar status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\",\n  \"note\": \"Atendimento iniciado\"\n}"
            },
            "url": "{{baseUrl}}/service-orders/{{serviceOrderId}}/status"
          }
        },
        {
          "name": "Historico da ordem",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/service-orders/{{serviceOrderId}}/history"
          }
        },
        {
          "name": "Exportar Excel (admin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/service-orders/export?format=excel"
          }
        },
        {
          "name": "Exportar PDF (admin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/service-orders/export?format=pdf"
          }
        }
      ]
    },
    {
      "name": "Attachments",
      "item": [
        {
          "name": "Upload anexo",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": "{{baseUrl}}/service-orders/{{serviceOrderId}}/attachments"
          }
        },
        {
          "name": "Listar anexos",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/service-orders/{{serviceOrderId}}/attachments"
          }
        },
        {
          "name": "Excluir anexo (admin)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/service-orders/{{serviceOrderId}}/attachments/{{attachmentId}}"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Metricas",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/dashboard/"
          }
        }
      ]
    }
  ]
}
